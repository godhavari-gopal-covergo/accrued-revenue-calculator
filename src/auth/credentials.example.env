# Copy to credentials.env in this folder (gitignored) and fill in values.
# Or export these variables in your shell before running fetch-token.

COVERGO_GRAPHQL_ENDPOINT=https://api.uat.ca.covergo.cloud/graphql
# Bearer JWT required on the token request (browser session / guest token from admin portal)
COVERGO_AUTH_BEARER=

COVERGO_TENANT_ID=gms
COVERGO_CLIENT_ID=admin_portal
COVERGO_USERNAME=your.user@covergo.com
COVERGO_PASSWORD=

# Optional: where to write the new API access token (default: ./current-token.txt)
# COVERGO_TOKEN_OUTPUT=./current-token.txt
